<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:id="@+id/cordinator_main">

    <include layout="@layout/content_filter_article" />

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/AppTheme.AppBarOverlay">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fitsSystemWindows="true"
            app:contentScrim="?attr/colorPrimary"
            app:expandedTitleGravity="center"
            app:expandedTitleTextAppearance="@android:color/transparent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed">
            <!--app:layout_scrollFlags="scroll|enterAlways|enterAlwaysCollapsed"-->
            <FrameLayout
                android:id="@+id/view_categorie"
                android:layout_width="match_parent"
                android:layout_height="@dimen/height_image_filter"
                android:orientation="vertical"
                android:visibility="visible">

                <ImageView
                    android:id="@+id/bg_categorie"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/height_image_filter"
                    android:fitsSystemWindows="true"
                    android:scaleType="fitXY"
                    android:src="@drawable/img_default_theme"
                    app:layout_collapseMode="parallax" />

                <RelativeLayout
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_gravity="bottom">

                    <ImageView
                        android:id="@+id/swipe_image"
                        android:layout_width="40dp"
                        android:layout_height="70dp"
                        android:layout_centerHorizontal="true"
                        android:src="@drawable/icon_swipe" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_marginBottom="55dp"
                        android:orientation="vertical"
                        android:paddingStart="15dp">



                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp">

                            <ImageView
                                android:id="@+id/image_bt_filter"
                                android:layout_width="120dp"
                                android:layout_height="40dp"
                                android:src="@drawable/bg_text_filter" />
                            <com.mdweb.tunnumerique.tools.style.TextViewTypo
                                android:id="@+id/text_button_filter"
                                android:layout_width="120dp"
                                android:layout_height="40dp"
                                android:gravity="center_vertical"
                                android:paddingStart="15dp"
                                android:text="SPORT"
                                android:textColor="@color/white_color"
                                app:sizeTypoText="16"
                                app:styleTypoText="book" />
                        </FrameLayout>



                        <com.mdweb.tunnumerique.tools.style.TextViewTypo
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="20dp"
                            android:text="@string/text_bg_image"
                            android:textColor="@color/white_color"
                            app:sizeTypoText="16"
                            app:styleTypoText="book" />
                    </LinearLayout>
                </RelativeLayout>


            </FrameLayout>

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/colorPrimary"
                app:layout_collapseMode="pin"
                app:popupTheme="@style/AppTheme.PopupOverlay">
                <!--app:collapseIcon="@drawable/icon_share_on"-->


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center">

                    <RelativeLayout
                        android:id="@+id/back_image"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:rotation="180"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"

                            android:src="@drawable/ic_back_white"/>
                    </RelativeLayout>

                    <com.mdweb.tunnumerique.tools.style.TextViewTypo
                        android:id="@+id/titleToolbar"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:gravity="start|center_vertical"
                        android:text=""
                        android:layout_marginTop="-5dp"
                        android:textColor="#fff"
                        app:sizeTypoText="18"
                        app:styleTypoText="book" />
                    <ImageView
                        android:layout_marginEnd="24dp"
                        android:src="@drawable/icon_fr"
                        android:id="@+id/lng_icon"
                        android:layout_gravity="end|center_vertical"

                        android:layout_width="20dp"
                        android:layout_height="28dp"/>


                </LinearLayout>
            </androidx.appcompat.widget.Toolbar>

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>
<!--    <com.google.android.material.floatingactionbutton.FloatingActionButton-->
