<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header avec logo -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:paddingStart="0dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="0dp"
        android:background="#FFFFFF">

        <ImageView
            android:id="@+id/drawerLogo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:paddingTop="16dp"
            android:paddingLeft="16dp"
            android:layout_toStartOf="@+id/closeDrawer"
            android:adjustViewBounds="true"
            android:contentDescription="Logo TN"
            android:scaleType="fitStart"
            android:src="@drawable/header_menu" />

        <ImageView
            android:id="@+id/closeDrawer"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:src="@drawable/ic_close_menu"
            android:padding="6dp"
            android:contentDescription="Fermer"
            android:clickable="true"
            android:focusable="true" />

    </RelativeLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <!-- ✅ RecyclerView CORRIGÉ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/menuRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clickable="false"
        android:focusable="false"
        android:descendantFocusability="afterDescendants" />

</LinearLayout>