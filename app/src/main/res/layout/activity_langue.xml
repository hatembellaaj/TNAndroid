<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Background identique au Splash -->
    <ImageView
        android:id="@+id/backgroundDie"
        android:layout_width="260dp"
        android:layout_height="516dp"
        android:src="@drawable/die"
        android:alpha="0.85"
        android:scaleType="fitXY"
        android:layout_gravity="start|top"
        android:translationX="41dp"
        android:translationY="-48dp" />

    <!-- Contenu -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_vertical|center_horizontal"> <!-- CENTRAGE VERTICAL + HORIZONTAL -->

            <!-- Logo -->
            <ImageView
                android:layout_width="240dp"
                android:layout_height="180dp"
                android:src="@drawable/logo_ar"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="50dp" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الرجاء إختيار اللغة"
                android:textSize="18dp"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:fontFamily="@font/arabic_regular"
                android:layout_gravity="center_horizontal"
                android:textDirection="rtl"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Please select a language "
                android:textSize="18dp"
                android:textColor="#FF2B2B2B"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp" />

            <!-- Titre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Veuillez sélectionner une langue"
                android:textSize="18dp"
                android:textColor="#FF2B2B2B"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="45dp" />

            <!-- Sous-titre arabe -->

            <!-- Options -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="25dp">

                <!-- arabe -->
                <RelativeLayout
                    android:id="@+id/option_arabic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:padding="20dp"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:id="@+id/radio_arabic"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/radio_unchecked" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="العربية"
                        android:textSize="18dp"
                        android:fontFamily="@font/arabic_medium"
                        android:textColor="#FF2B2B2B"
                        android:gravity="center" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E5E5" />

                <!-- English -->
                <RelativeLayout
                    android:id="@+id/option_english"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:padding="20dp"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:id="@+id/radio_english"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/radio_unchecked" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="English"
                        android:textSize="18dp"
                        android:textColor="#FF2B2B2B"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E5E5" />

                <!-- Français -->
                <RelativeLayout
                    android:id="@+id/option_french"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:padding="20dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/radio_french"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_check_circle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="Français"
                        android:textSize="18dp"
                        android:textColor="#FF2B2B2B"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center" />
                </RelativeLayout>

            </LinearLayout>

            <!-- Bouton OK -->
            <Button
                android:id="@+id/btn_ok"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OK"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-bold"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:background="@drawable/button_green_bg"
                android:stateListAnimator="@null" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>
