<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context="com.mdweb.tunnumerique.ui.fragments.ArticleFavoriFragment">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_news"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

        <RelativeLayout
            android:id="@+id/empty_listeA"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
      >
          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="vertical"
              android:gravity="center"
              android:layout_centerInParent="true">
            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/icon_info"/>
            <com.mdweb.tunnumerique.tools.style.TextViewTypo
                android:paddingRight="16dp"
                android:paddingLeft="16dp"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:styleTypoText="oblique"
                android:lineSpacingMultiplier="1.3"
                app:sizeTypoText="18"
                android:textColor="@color/color_default_text"
                android:text="@string/text_vide_favori_a"/>
          </LinearLayout>
        </RelativeLayout>
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        app:fabCustomSize="60dp"
        android:id="@+id/fab_guide"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:visibility="gone"
        android:layout_gravity="bottom|end"
        android:layout_margin="15dp"
        android:src="@drawable/ic_icon_capture"
        />
</FrameLayout>
