<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white_color"
    android:orientation="vertical">


    <ScrollView
        android:layout_width="match_parent"
        android:fillViewport="true"
        android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white_color"
         android:descendantFocusability="beforeDescendants"
        android:focusableInTouchMode="true"
        android:focusable="true"
        android:fitsSystemWindows="true"
        android:orientation="vertical">
        <com.huawei.hms.ads.banner.BannerView
            xmlns:hwads="http://schemas.android.com/apk/res-auto"
            android:id="@+id/hw_banner_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            hwads:adId="l4yj9fiyhp"
            android:visibility="gone"
            hwads:bannerSize="BANNER_SIZE_320_100" >
        </com.huawei.hms.ads.banner.BannerView>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_height="match_parent">
    <WebView
        android:id="@+id/blague"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp"
        android:gravity="right"
        android:padding="16dp"
        android:textColor="@color/black_color"
        app:layout_constraintTop_toTopOf="parent"
       />
            <LinearLayout
                android:id="@+id/rating_bar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginLeft="24dp"
                android:gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:layout_marginRight="24dp"
                android:layout_marginBottom="16dp"

                android:orientation="horizontal"
                app:layout_constraintBottom_toTopOf="@id/devider"
                app:layout_constraintLeft_toLeftOf="parent"

                app:layout_constraintRight_toRightOf="parent">

                <LinearLayout
                    android:id="@+id/shareBtn"
                    android:layout_width="130dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_share_btn"

                    android:gravity="center"
                    android:orientation="horizontal">

                    <com.mdweb.tunnumerique.tools.style.TextViewTypo
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/share_text"
                        android:textColor="#fff"
                        app:sizeTypoText="16"
                        app:styleTypoText="oblique" />


                </LinearLayout>

            </LinearLayout>
        </LinearLayout>


    </LinearLayout>
    </ScrollView>

</FrameLayout>
